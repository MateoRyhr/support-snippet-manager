// api/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid())
  username  String    @unique
  email     String    @unique
  password  String    // Aquí guardaremos el hash, nunca la contraseña en texto plano
  
  // Relación: Un usuario puede tener muchos snippets
  snippets  Snippet[] 
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  folders   Folder[]
}

model Snippet {
  id          String    @id @default(uuid())
  title       String
  content     String    @db.Text
  language    String    @default("plaintext") // Agregado para coincidir con tu UI de Electron
  isPublic    Boolean   @default(false)       // Privado por defecto (Seguridad primero)
  usageCount  Int       @default(0)           // Mantenemos tu contador de usos original
  
  // Clave foránea y relación con User
  userId      String
  author      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Relación Muchos-a-Muchos explícita (Prisma crea la tabla intermedia automáticamente)
  tags        Tag[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Hacemos que folderId sea opcional (String?) por si hay snippets "sueltos"
  folderId  String?   
  folder    Folder?   @relation(fields: [folderId], references: [id], onDelete: SetNull)
}

model Tag {
  id        String    @id @default(uuid())
  name      String    @unique // Único para no tener tags repetidos ("react", "React", etc)
  
  // Relación inversa: Un tag puede pertenecer a muchos snippets
  snippets  Snippet[]
  
  createdAt DateTime  @default(now())
}

model Folder {
  id        String    @id @default(uuid())
  name      String
  
  // Relación con el Usuario (Dueño de la carpeta)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Relación con los Snippets
  snippets  Snippet[] 

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Opcional pero recomendado: Un usuario no debería tener dos carpetas con el mismo nombre
  @@unique([name, userId]) 
}